@model List<Order>

@{
    ViewData["Title"] = "Search Orders";
}

<div class="container mt-5">
    <h2>Search Orders</h2>
    
    <form method="get" asp-action="SearchVulnerable" class="mb-4">
        <div class="input-group">
            <input type="text" name="keyword" class="form-control" placeholder="Search by title or amount..." />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Search
            </button>
        </div>
    </form>

    @if (Model?.Count > 0)
    {
        <div class="alert alert-success">
            Found @Model.Count result(s)
        </div>
        
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Amount</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.Title</td>
                        <td>$@order.Amount</td>
                        <td>
                            <a href="@Url.Action("Details", "Orders", new { id = order.Id })" class="btn btn-sm btn-primary">
                                View Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No results found. Try a different search term.
        </div>
    }
</div>
